# SprintPilot AI -- Backend Environment
# Copy to .env and populate.

# LLM Provider
OPENAI_API_KEY=

# Server
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info

# CrewAI
CREWAI_VERBOSE=false
CREWAI_MAX_RPM=60
CREWAI_STORAGE_DIR=./project-context/2.build/logs

# Database
DATABASE_URL=sqlite:///./sprintpilot.db
