# SprintPilot AI -- Environment Configuration
# Copy to .env and populate with your values.

# ── AAMAD Framework ──────────────────────────────────────────────────
AAMAD_ADAPTER=crewai

# ── LLM Provider (SAD-MVP Section 2 -- OpenAI GPT-4-class) ──────────
OPENAI_API_KEY=

# ── Backend (FastAPI) ────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info

# ── Frontend (Next.js) ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APP_NAME=SprintPilot AI

# ── CrewAI Configuration (SAD-MVP Section 2) ────────────────────────
CREWAI_VERBOSE=false
CREWAI_MAX_RPM=60
CREWAI_STORAGE_DIR=./project-context/2.build/logs

# ── Database (SAD-MVP Section 4 -- SQLite for MVP) ──────────────────
DATABASE_URL=sqlite:///./sprintpilot.db
